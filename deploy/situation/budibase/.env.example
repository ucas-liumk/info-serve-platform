# Budibase low-code app factory.
# Copy to .env or run start-budibase.sh to generate a local .env with random secrets.

MAIN_PORT=18100

# These secrets must be changed for every environment.
API_ENCRYPTION_KEY=change-me-api-encryption-key
JWT_SECRET=change-me-jwt-secret
MINIO_ACCESS_KEY=budibase
MINIO_SECRET_KEY=change-me-minio-secret
COUCH_DB_USER=budibase
COUCH_DB_PASSWORD=change-me-couchdb-password
REDIS_USERNAME=
REDIS_PASSWORD=change-me-redis-password
INTERNAL_API_KEY=change-me-internal-api-key
LITELLM_MASTER_KEY=change-me-litellm-master-key
LITELLM_SALT_KEY=change-me-litellm-salt-key

# Optional first admin account. Leave empty to create it through the Budibase UI.
BB_ADMIN_USER_EMAIL=
BB_ADMIN_USER_PASSWORD=

# Official image defaults. Pin these tags during production packaging if required.
BUDIBASE_APPS_IMAGE=budibase/apps:latest
BUDIBASE_WORKER_IMAGE=budibase/worker:latest
BUDIBASE_PROXY_IMAGE=budibase/proxy:latest
BUDIBASE_DATABASE_IMAGE=budibase/database:2.1.0
BUDIBASE_MINIO_IMAGE=minio/minio:latest
BUDIBASE_REDIS_IMAGE=redis:7.4-alpine
BUDIBASE_LITELLM_IMAGE=ghcr.io/berriai/litellm:main-v1.83.10-stable
BUDIBASE_LITELLM_DB_IMAGE=postgres:16-alpine

BUDIBASE_ENVIRONMENT=PRODUCTION
SQL_MAX_ROWS=
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=llmproxy
LITELLM_DB_PASSWORD=change-me-litellm-db-password
LITELLM_URL=
PLUGINS_DIR=
OFFLINE_MODE=true
ROLLING_LOG_MAX_SIZE=
