COMPOSE_PROJECT_NAME=infosys-ruoyi-cloud-plus

# 仓库内产品版本以根目录 VERSION 为唯一来源；目标机上此值由更新脚本维护
INFO_SERVE_VERSION=0.3.5
RUOYI_CLOUD_VERSION=2.6.2
# MySQL 仅作为 Nacos 配置库（ry-config）
MYSQL_IMAGE=mysql:8.0
# PostgreSQL 承载全部业务库（ry-cloud / ry-job / ry-workflow）
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7.4-alpine
RABBITMQ_IMAGE=rabbitmq:3.12-management
MINIO_IMAGE=minio/minio:RELEASE.2025-02-18T16-25-55Z
NGINX_IMAGE=nginx:1.27-alpine

MYSQL_ROOT_PASSWORD=ruoyi123
POSTGRES_USER=ruoyi
POSTGRES_PASSWORD=ruoyi123
POSTGRES_DB=ruoyi
REDIS_PASSWORD=ruoyi123
RABBITMQ_DEFAULT_USER=ruoyi
RABBITMQ_DEFAULT_PASS=ruoyi123
MINIO_ROOT_USER=ruoyi
MINIO_ROOT_PASSWORD=ruoyi123

NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

NACOS_IMAGE=infosys/ruoyi-cloud-plus-nacos:2.6.2
GATEWAY_IMAGE=infosys/ruoyi-cloud-plus-gateway:2.6.2
AUTH_IMAGE=infosys/ruoyi-cloud-plus-auth:2.6.2
SYSTEM_IMAGE=infosys/ruoyi-cloud-plus-system:2.6.2
FILE_IMAGE=infosys/ruoyi-cloud-plus-file:2.6.2
MONITOR_IMAGE=infosys/ruoyi-cloud-plus-monitor:2.6.2
PORTAL_IMAGE=infosys/ruoyi-cloud-plus-portal:2.6.2
